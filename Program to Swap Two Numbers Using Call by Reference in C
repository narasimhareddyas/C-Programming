//Program to Swap Two Numbers Using Call by Reference in C//


#include <stdio.h>

int a, b;

void swap(int *x, int *y);

void main(void)
{
    printf("Enter the value a: ");
    scanf("%d", &a);

    printf("Enter the value b: ");
    scanf("%d", &b);

    swap(&a, &b);

    printf("a = %d\n", a);
    printf("b = %d\n", b);
}

void swap(int *x, int *y)
{
    *x = *x + *y;
    *y = *x - *y;
    *x = *x - *y;
}
